# Supabase — get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe — get these from your Stripe Dashboard > Developers > API keys
STRIPE_SECRET_KEY=sk_test_your-secret-key-here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# Resend — get your API key from resend.com/api-keys
RESEND_API_KEY=re_your-api-key-here

# Email the contact form sends TO (your business email)
CONTACT_EMAIL=your-business@email.com

# Email the contact form sends FROM (must be verified in Resend, or use onboarding@resend.dev for testing)
RESEND_FROM_EMAIL=onboarding@resend.dev
